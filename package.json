{
  "name": "clippy-js",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "generate": "node ./scripts/generate-assets.mjs",
    "build": "pnpm generate && tsup src/index.ts --format esm --dts --clean && node ./scripts/copy-dist-assets.mjs",
    "demo": "vite --config demo/vite.config.ts",
    "demo:build": "vite build --config demo/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm build"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.3",
    "react": "^19.1.1",
    "react-dom": "^19.2.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.12"
  }
}
